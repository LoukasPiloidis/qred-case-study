{
	"name": "qred-case-study",
	"version": "1.0.0",
	"description": "Qred banking backend case study",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"db:start": "docker compose up -d",
		"db:stop": "docker compose down",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "npx tsx src/lib/db/seed.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "tsc && biome check .",
		"lint:fix": "biome check --write ."
	},
	"engines": {
		"node": ">=25"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/rate-limit": "^10.3.0",
		"@fastify/swagger": "^9.7.0",
		"@scalar/fastify-api-reference": "^1.53.0",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.8.5",
		"fastify-type-provider-zod": "^6.1.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.9",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@electric-sql/pglite": "^0.4.5",
		"@types/node": "^25.6.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
